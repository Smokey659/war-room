/* War Room v1 — minimal, readable, no framework. */

:root {
    --bg: #0f1115;
    --bg-elev: #161922;
    --bg-elev-2: #1d212c;
    --border: #2a2f3a;
    --text: #e6e8ec;
    --text-muted: #8a93a3;
    --accent: #5b9dff;
    --accent-hover: #7eb1ff;
    --user-msg: #1d2434;
    --asst-msg: #161a23;
    --error: #ff6b6b;
    --success: #5fd07a;
    --mono: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    --sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
}

* { box-sizing: border-box; }

html, body {
    margin: 0;
    padding: 0;
    height: 100%;
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-size: 15px;
    line-height: 1.5;
}

.app {
    display: grid;
    grid-template-columns: 280px 1fr;
    height: 100vh;
}

/* ---------- Sidebar ---------- */

.sidebar {
    background: var(--bg-elev);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

.sidebar-header {
    padding: 16px;
    border-bottom: 1px solid var(--border);
}

.sidebar-header h1 {
    margin: 0 0 12px 0;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 0.3px;
}

.sidebar-actions {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.sidebar-threads {
    flex: 1;
    overflow-y: auto;
    padding: 8px 0;
}

.thread-list {
    list-style: none;
    margin: 0;
    padding: 0;
}

.thread-list li {
    border-bottom: 1px solid transparent;
}

.thread-link {
    display: block;
    padding: 10px 16px;
    color: var(--text);
    text-decoration: none;
    font-size: 14px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    border-left: 2px solid transparent;
}

.thread-link:hover {
    background: var(--bg-elev-2);
    border-left-color: var(--accent);
}

/* ---------- Chat pane ---------- */

.chat-pane {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: var(--bg);
}

.chat-header {
    padding: 16px 24px;
    border-bottom: 1px solid var(--border);
}

.chat-header h2 {
    margin: 0;
    font-size: 16px;
    font-weight: 500;
    color: var(--text-muted);
}

.messages {
    flex: 1;
    overflow-y: auto;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
}

/* ---------- Message bubbles ---------- */

.message {
    max-width: 880px;
    border-radius: 10px;
    padding: 14px 18px;
    border: 1px solid var(--border);
}

.message-user {
    background: var(--user-msg);
    align-self: flex-end;
    margin-left: 60px;
}

.message-assistant {
    background: var(--asst-msg);
    align-self: flex-start;
    margin-right: 60px;
}

.message-role {
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 0.6px;
    color: var(--text-muted);
    margin-bottom: 6px;
    font-weight: 600;
}

.message-content {
    color: var(--text);
    word-wrap: break-word;
}

.message-content a.wikilink {
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
}

.message-content a.wikilink:hover {
    color: var(--accent-hover);
    text-decoration: underline;
}

.message-sources {
    margin-top: 12px;
    padding-top: 10px;
    border-top: 1px dashed var(--border);
}

.sources-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--text-muted);
    margin-bottom: 6px;
    font-weight: 600;
}

.message-sources ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
}

.message-sources li a {
    display: inline-block;
    padding: 3px 8px;
    background: var(--bg-elev-2);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text-muted);
    font-size: 12px;
    text-decoration: none;
    font-family: var(--mono);
}

.message-sources li a:hover {
    color: var(--accent);
    border-color: var(--accent);
}

.message-meta {
    margin-top: 8px;
    font-size: 11px;
    font-family: var(--mono);
}

.cursor-blink {
    display: inline-block;
    animation: blink 1s steps(1) infinite;
    color: var(--accent);
}

@keyframes blink {
    50% { opacity: 0; }
}

.error {
    color: var(--error);
    font-family: var(--mono);
    font-size: 13px;
}

/* ---------- Composer ---------- */

.composer {
    border-top: 1px solid var(--border);
    padding: 16px 24px;
    background: var(--bg-elev);
    display: flex;
    gap: 12px;
    align-items: flex-end;
}

.composer textarea {
    flex: 1;
    background: var(--bg);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 12px;
    font: inherit;
    font-size: 14px;
    resize: vertical;
    min-height: 60px;
    max-height: 200px;
}

.composer textarea:focus {
    outline: none;
    border-color: var(--accent);
}

/* ---------- Buttons ---------- */

button {
    font: inherit;
    cursor: pointer;
}

.btn-primary {
    background: var(--accent);
    color: white;
    border: 1px solid var(--accent);
    padding: 8px 14px;
    border-radius: 6px;
    font-weight: 500;
    font-size: 14px;
}

.btn-primary:hover {
    background: var(--accent-hover);
    border-color: var(--accent-hover);
}

.btn-secondary {
    background: var(--bg-elev-2);
    color: var(--text);
    border: 1px solid var(--border);
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 13px;
}

.btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
}

/* ---------- Welcome screen ---------- */

.welcome {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 40px;
}

.welcome h2 {
    font-size: 28px;
    font-weight: 500;
    margin: 0 0 12px 0;
}

.welcome p {
    color: var(--text-muted);
    max-width: 540px;
    margin: 6px 0;
}

.welcome em {
    color: var(--text);
    font-style: normal;
    font-family: var(--mono);
    font-size: 13px;
}

/* ---------- Misc ---------- */

.muted {
    color: var(--text-muted);
    font-size: 13px;
    padding: 8px 16px;
}

.reindex-status {
    color: var(--success);
    font-size: 12px;
    padding-top: 4px;
}

/* ---------- Dashboard (tile grid) ---------- */

.dashboard-body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    padding: 40px 56px;
    max-width: 1280px;
    margin: 0 auto;
}

.dashboard-header {
    margin-bottom: 36px;
}

.dashboard-header h1 {
    margin: 0 0 6px 0;
    font-size: 32px;
    font-weight: 600;
    letter-spacing: -0.5px;
}

.dashboard-header .muted {
    padding: 0;
    font-size: 15px;
}

.tile-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
    flex: 1;
    align-content: flex-start;
}

.tile {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px 20px 20px 20px;
    color: var(--text);
    text-decoration: none;
    transition: transform 0.08s, border-color 0.08s, background 0.08s;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-height: 180px;
}

.tile:hover {
    border-color: var(--accent);
    background: var(--bg-elev-2);
    transform: translateY(-1px);
}

.tile-disabled {
    opacity: 0.55;
}

.tile-disabled:hover {
    border-color: var(--border);
    background: var(--bg-elev);
    transform: none;
}

.tile-icon {
    font-size: 32px;
    line-height: 1;
    margin-bottom: 4px;
}

.tile-title {
    margin: 0;
    font-size: 18px;
    font-weight: 600;
}

.tile-description {
    margin: 0;
    color: var(--text-muted);
    font-size: 13px;
    line-height: 1.45;
    flex: 1;
}

.tile-status {
    margin-top: 8px;
    font-size: 12px;
    padding: 4px 10px;
    border-radius: 6px;
    align-self: flex-start;
    font-family: var(--mono);
    font-weight: 500;
}

.tile-status.status-live {
    background: rgba(95, 208, 122, 0.12);
    color: var(--success);
    border: 1px solid rgba(95, 208, 122, 0.25);
}

.tile-status.status-soon {
    background: var(--bg-elev-2);
    color: var(--text-muted);
    border: 1px solid var(--border);
}

.dashboard-footer {
    margin-top: 32px;
    padding: 16px 0 0 0;
    border-top: 1px solid var(--border);
    font-size: 12px;
}

.dashboard-footer code {
    font-family: var(--mono);
    color: var(--text-muted);
}

/* ---------- Brain (chat shell) — back link in sidebar ---------- */

.back-link {
    display: inline-block;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 12px;
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    font-weight: 500;
}

.back-link:hover {
    color: var(--accent);
}

/* ---------- Coming-soon page ---------- */

.coming-soon-body {
    background: var(--bg);
}

.coming-soon {
    max-width: 720px;
    margin: 60px auto;
    padding: 0 32px;
}

.coming-soon-card {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 40px;
    margin-top: 16px;
}

.coming-soon-icon {
    font-size: 48px;
    margin-bottom: 12px;
}

.coming-soon-card h1 {
    margin: 0 0 12px 0;
    font-size: 28px;
    font-weight: 600;
}

.coming-soon-card .lead {
    font-size: 15px;
    margin: 0 0 28px 0;
    padding: 0;
}

.planned-section h3 {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--text-muted);
    margin: 0 0 12px 0;
    font-weight: 600;
}

.planned-list {
    list-style: none;
    padding: 0;
    margin: 0 0 28px 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.planned-list li {
    padding: 10px 14px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 14px;
}

.coming-soon-card .small {
    font-size: 12px;
    line-height: 1.5;
    padding: 0;
}

/* ---------- Markdown content (Claude responses) ---------- */

.message-content h1,
.message-content h2,
.message-content h3,
.message-content h4 {
    margin: 16px 0 8px 0;
    font-weight: 600;
    line-height: 1.3;
}

.message-content h1 { font-size: 20px; }
.message-content h2 { font-size: 17px; }
.message-content h3 { font-size: 15px; }
.message-content h4 { font-size: 14px; color: var(--text-muted); }

.message-content h1:first-child,
.message-content h2:first-child,
.message-content h3:first-child {
    margin-top: 0;
}

.message-content p {
    margin: 0 0 10px 0;
}

.message-content p:last-child {
    margin-bottom: 0;
}

.message-content ul,
.message-content ol {
    margin: 0 0 10px 0;
    padding-left: 24px;
}

.message-content li {
    margin-bottom: 4px;
}

.message-content strong {
    font-weight: 600;
    color: var(--text);
}

.message-content em {
    font-style: italic;
    color: var(--text);
}

.message-content code {
    font-family: var(--mono);
    background: var(--bg);
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 13px;
    color: var(--accent);
}

.message-content pre {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 12px;
    overflow-x: auto;
    margin: 10px 0;
}

.message-content pre code {
    background: none;
    padding: 0;
    color: var(--text);
    font-size: 12px;
}

.message-content blockquote {
    border-left: 3px solid var(--accent);
    margin: 10px 0;
    padding: 4px 14px;
    color: var(--text-muted);
    background: var(--bg);
}

.message-content hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 16px 0;
}

.message-content a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: rgba(91, 157, 255, 0.4);
}

.message-content a:hover {
    text-decoration-color: var(--accent);
}

/* ---------- Agent pages (X Agent + future tile drill-downs) ---------- */

.x-agent-body {
    background: var(--bg);
}

.agent-page {
    max-width: 1280px;
    margin: 0 auto;
    padding: 32px 40px;
}

.agent-page-header h1 {
    margin: 8px 0 4px 0;
    font-size: 26px;
    font-weight: 600;
}

.agent-page-header .muted {
    padding: 0;
    font-size: 14px;
}

.agent-page-header .muted code {
    font-family: var(--mono);
    background: var(--bg-elev);
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 12px;
    color: var(--accent);
}

.agent-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 24px;
    margin-top: 28px;
}

.agent-sidebar {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px;
    align-self: flex-start;
    position: sticky;
    top: 16px;
}

.agent-sidebar h3 {
    margin: 0 0 10px 0;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--text-muted);
    font-weight: 600;
}

.past-briefs {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.past-brief-link {
    display: block;
    padding: 6px 8px;
    border-radius: 4px;
    color: var(--text);
    text-decoration: none;
    font-size: 13px;
    border-left: 2px solid transparent;
}

.past-brief-link:hover {
    background: var(--bg-elev-2);
    border-left-color: var(--accent);
}

.past-brief-link.active {
    background: var(--bg-elev-2);
    border-left-color: var(--accent);
    color: var(--accent);
}

.past-brief-link .muted {
    font-size: 11px;
    padding: 0;
    margin-left: 6px;
    color: var(--text-muted);
}

.agent-main {
    min-width: 0;
}

.brief-section {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px;
}

.brief-section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 18px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
}

.brief-section-header h2 {
    margin: 0;
    font-size: 18px;
    font-weight: 600;
}

.brief-actions {
    display: flex;
    gap: 8px;
}

.brief-empty {
    padding: 32px 0;
    text-align: center;
    font-size: 14px;
}

.brief-rendered {
    color: var(--text);
}

.brief-output {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.brief-streaming-header {
    font-size: 13px;
    font-family: var(--mono);
    padding: 0;
}

.subprocess-output {
    background: var(--bg);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 12px 14px;
    font-family: var(--mono);
    font-size: 12px;
    line-height: 1.45;
    overflow-x: auto;
    max-height: 320px;
    overflow-y: auto;
    white-space: pre-wrap;
    word-break: break-word;
    margin: 0;
}

.brief-output details {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 8px 12px;
}

.brief-output details > summary {
    cursor: pointer;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 4px 0;
}

.brief-output details[open] > summary {
    margin-bottom: 8px;
}

.brief-output details .subprocess-output {
    margin-top: 8px;
    border: none;
    background: transparent;
    padding: 0;
    max-height: 200px;
}

/* ---------- Reply-bot card (X agent page card 2) ---------- */

.reply-bot-section {
    margin-top: 18px;
}

.reply-bot-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 18px;
}

.account-picker {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.account-picker-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--text-muted);
    font-weight: 600;
    margin-bottom: 4px;
}

.account-option {
    display: grid;
    grid-template-columns: 20px 1fr;
    gap: 8px 12px;
    padding: 12px 14px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    cursor: pointer;
    transition: border-color 0.08s, background 0.08s;
}

.account-option:hover {
    border-color: var(--accent);
}

.account-option input[type="radio"] {
    grid-row: 1 / span 2;
    margin: 4px 0 0 0;
    accent-color: var(--accent);
    cursor: pointer;
}

.account-option-name {
    font-weight: 600;
    color: var(--text);
    font-size: 14px;
}

.account-option-desc {
    grid-column: 2;
    font-size: 12px;
    padding: 0;
}

.reply-bot-form button[type="submit"] {
    align-self: flex-start;
}

.reply-bot-form button[type="submit"]:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

/* ===========================================================================
 * Trading tile — strategy cards with chart outputs
 * =========================================================================== */

.trading-strategies {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 1100px;
    margin: 0 auto;
}

.strategy-card {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 20px 24px;
}

.strategy-header h2 {
    margin: 0 0 6px 0;
    font-size: 18px;
}

.strategy-description {
    margin: 0 0 16px 0;
    font-size: 13px;
    line-height: 1.45;
}

.strategy-form {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 14px 16px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    margin-bottom: 16px;
}

.strategy-args {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
}

.strategy-arg {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.arg-label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-muted);
    font-weight: 600;
}

.arg-input {
    padding: 6px 10px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text);
    font-family: inherit;
    font-size: 13px;
}

.arg-input:focus {
    outline: 1px solid var(--accent);
    border-color: var(--accent);
}

.arg-help {
    font-size: 11px;
    line-height: 1.3;
}

.strategy-form button[type="submit"] {
    align-self: flex-start;
}

.strategy-form button[type="submit"]:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.strategy-output-container {
    margin-top: 8px;
}

.strategy-output {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.strategy-empty {
    padding: 20px;
    text-align: center;
    border: 1px dashed var(--border);
    border-radius: 6px;
}

.strategy-streaming-header {
    font-size: 13px;
    padding: 8px 12px;
    background: var(--bg);
    border-radius: 4px;
    border-left: 3px solid var(--accent);
}

.strategy-chart-wrapper {
    background: white;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 8px;
    overflow: auto;
}

.strategy-chart {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 0 auto;
}

.strategy-meta {
    font-size: 12px;
    text-align: right;
}

/* ===========================================================================
 * Trading entry-point card (links to a sub-view like Futures Map)
 * =========================================================================== */

.trading-entrypoint {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.trading-entrypoint .btn-primary {
    align-self: flex-start;
    text-decoration: none;
}

.btn-sm {
    padding: 4px 12px;
    font-size: 12px;
}

/* ===========================================================================
 * Futures Map — sector grid of micro contracts with quote + sparkline
 * =========================================================================== */

.futures-grid {
    display: flex;
    flex-direction: column;
    gap: 28px;
    max-width: 1100px;
    margin: 0 auto;
}

.futures-sector-title {
    margin: 0 0 12px 0;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-muted);
}

.futures-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 12px;
}

.futures-card {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-height: 96px;
}

.futures-card.active {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent) inset;
}

.fc-header {
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.fc-ticker {
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.5px;
}

.fc-star {
    color: var(--accent);
    margin-right: 4px;
}

.fc-name {
    font-size: 11px;
    line-height: 1.2;
}

.fc-price {
    font-family: var(--mono);
    font-size: 18px;
    font-weight: 600;
    color: var(--text);
}

.fc-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
}

.fc-change {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 600;
}

/* Direction-driven colors — apply to both .fc-change and the sparkline stroke
 * (which uses currentColor). .fc-spark inherits via the parent .futures-card. */
.futures-card.up    { color: var(--success); }
.futures-card.down  { color: var(--error); }
.futures-card.flat  { color: var(--text-muted); }

/* Keep the ticker + name + price legible (not green/red) — only the change
 * and sparkline carry the directional color. */
.futures-card .fc-ticker,
.futures-card .fc-name,
.futures-card .fc-price {
    color: var(--text);
}
.futures-card .fc-name { color: var(--text-muted); }

.fc-spark {
    display: inline-flex;
    align-items: center;
    height: 22px;
}

.fc-spark .spark { display: block; }

.fc-error {
    font-size: 11px;
    font-style: italic;
}

.futures-statusbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 12px;
    margin-top: 8px;
}
